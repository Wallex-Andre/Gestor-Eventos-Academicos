<?xml version="1.0" encoding="utf-8"?>

<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:label="@string/app_name"
        android:icon="@drawable/logo_app"
        android:roundIcon="@drawable/logo_app"
        android:supportsRtl="true"
        android:theme="@style/Theme.gestoreventos"
        tools:targetApi="31">



        <receiver
            android:name=".receiver.EventoReceiver"
            android:exported="false"/>

        <!-- Splash -->
        <activity
            android:name=".SplashActivity"
            android:exported="true">

            <intent-filter>

                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />

            </intent-filter>

        </activity>


        <!-- Onboarding -->
        <activity
            android:name=".OnboardingActivity"
            android:exported="false"/>

        <!-- Main -->
        <activity
            android:name=".MainActivity"
            android:exported="false"/>

        <!-- Cadastro -->
        <activity
            android:name=".EventoActivity"
            android:exported="false"/>

        <!-- Editar -->
        <activity
            android:name=".EditarEventoActivity"
            android:exported="false"/>

        <!-- Todos eventos -->
        <activity
            android:name=".TodosEventosActivity"
            android:exported="false"/>

        <!-- Dashboard -->
        <activity
            android:name=".DashboardActivity"
            android:exported="false"/>

    </application>

</manifest>